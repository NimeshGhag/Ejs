<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Gilroy';
        }

        html,
        body {
            height: 100%;
            width: 100%;
        }

        h1 {
            text-align: center;
            font-size: 3rem;
            margin: 20px;
        }

        p {
            text-align: center;
            font-size: 3rem;
            margin: 20px;
        }
    </style>
</head>

<body>

    <% messages.forEach(message=> { %>
        <p>
            <%- message %>
        </p>
        <% }) %>

</body>

</html>